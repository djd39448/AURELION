# =============================================================================
# AURELION — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED for local development
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.XXXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# OPTIONAL — defaults shown in parentheses
# ---------------------------------------------------------------------------
# PORT=3001                          # API server port (3001)
# SESSION_SECRET=change-me           # Session cookie secret (dev fallback used)
# BASE_PATH=/                        # Vite base path (/)
# LOG_LEVEL=info                     # Pino log level (info)
# API_URL=http://localhost:3001      # Vite proxy target for /api

# ---------------------------------------------------------------------------
# STRIPE — leave commented out for mock mode
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# OPENAI — leave commented out for mock chat responses
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# PRODUCTION ONLY
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=https://your-domain.com
