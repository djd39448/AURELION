{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/aurelion run build",
  "outputDirectory": "artifacts/aurelion/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api-server-production-2f10.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
